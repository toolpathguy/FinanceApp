; Sample hledger journal for YNAB-style envelope budgeting
; Transactions follow the envelope model:
;   Income:  assets:checking ← income:category
;   Budget Assignment: assets:checking:budget:* ← assets:checking (with = $0.00 assertion)
;   Expense: expenses:category ← assets:checking:budget:category
;   Credit Card Expense: 4-posting (expense, budget credit, pending CC debit, liability credit)
;   Transfer between envelopes: budget:dest ← budget:source

account assets:checking
account assets:savings
account liabilities:credit-card
account income:salary
account income:freelance
account expenses:food:groceries
account expenses:food:restaurants
account expenses:housing:rent
account expenses:housing:utilities
account expenses:transport
account expenses:entertainment

; ── January 2025 ──

2025-01-05 * Salary
    assets:checking                    $3500.00
    income:salary

2025-01-05 * Budget Assignment
    assets:checking:budget:housing:rent          $1200.00
    assets:checking:budget:housing:utilities       $150.00
    assets:checking:budget:food:groceries          $400.00
    assets:checking:budget:food:restaurants         $100.00
    assets:checking:budget:transport                $100.00
    assets:checking:budget:entertainment             $50.00
    assets:checking:budget:unallocated            $1500.00
    assets:checking                                          = $0.00

2025-01-10 * Rent
    expenses:housing:rent              $1200.00
    assets:checking:budget:housing:rent

2025-01-12 * Electric bill
    expenses:housing:utilities            $95.00
    assets:checking:budget:housing:utilities

2025-01-15 * Restaurant dinner
    expenses:food:restaurants             $45.00
    assets:checking:budget:food:restaurants       $-45.00
    assets:checking:budget:pending:credit-card     $45.00
    liabilities:credit-card                       $-45.00

2025-01-18 * Freelance payment
    assets:checking                      $500.00
    income:freelance

2025-01-18 * Budget Assignment
    assets:checking:budget:unallocated   $500.00
    assets:checking                                = $0.00

2025-01-20 * Gas station
    expenses:transport                    $55.00
    assets:checking:budget:transport

2025-01-22 * Movie tickets
    expenses:entertainment                $30.00
    assets:checking:budget:entertainment         $-30.00
    assets:checking:budget:pending:credit-card    $30.00
    liabilities:credit-card                      $-30.00

2025-01-25 * Transfer to savings
    assets:savings                       $500.00
    assets:checking:budget:unallocated

